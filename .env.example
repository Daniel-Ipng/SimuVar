# PostgreSQL Database Connection
# Option A: Connection string (Neon / Vercel Postgres / Supabase)
POSTGRES_URL=postgresql://user:password@host:5432/database?sslmode=require

# Option B: Individual parameters (local PostgreSQL)
# PGHOST=localhost
# PGUSER=postgres
# PGPASSWORD=postgres
# PGDATABASE=simulacion_db
# PGPORT=5432
# PGSSL=false

# JWT Secret (change in production)
JWT_SECRET=your_custom_jwt_secret_here

# Server Port (local development only)
PORT=3000
